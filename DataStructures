#include <fstream>
#include <sstream>
#include <regex>

struct Line { //Individual Line (e.g. Devanagari, IAST,  Eng)
	std::string raw;
};

struct Verse { //Verse Number, and each Line rendering in the Verse
	int verseNumber;

	Line dev;
	Line iast;
	Line eng;

	std::std::vector<std::string> dev_words;
	std::std::vector<std::string> iast_words;
	std::std::vector<std::string> eng_words;
};

struct Hymn {//All verses
	std::vector<Verse> verses;
};


std::string readFile(const std::string& filename) {
	std::ifstream file(filename);
	std::stringstream buffer;
	buffer << file.rdbuf();
	return buffer.str();
}

std::vector<std::string> splitVerses(const std::string& text) {
	std::vector<std::string> verses;

	std::regex verse_regex(R"(\[Verse\s+\d+\])");
	std::sregex_token_iterator iter(text.begin(), text.end(), verse_regex, -1);
	std::sregex_token_iterator end;

	for(; iter != end; ++iter) {
		if (!iter->str().empty()){
			verses.push_back(iter->str());
	}
}

	return verses;
}

Verse parseVerse(const std::string& block, int verseNumber) {
	Verse v;
	v.number = verseNumber

	std::regex dev_re(R"(DEV:\s*(.*))");
	std::regex iast_re(R"(IAST:\s*(.*))");
	std::regex eng_re(R"(ENG:\s*(.*))");

	std::smatch match;

	if (std::regex_search(block,match, dev_re)) {
		v.dev.raw = match[1];
	}

	if (std::regex_search(block, match, iast_re)) {
	        v.iast.raw = match[1];
	}

	if (std::regex_search(block, match, eng_re)) {
	        v.eng.raw = match[1];
	}

	    return v;
}

std::vector<std::string> tokenize(const std::string& text) {
    std::vector<std::string> words;
    std::stringstream ss(text);
    std::string word;

    while (ss >> word) {
        words.push_back(word);
    }

    return words;
}

v.dev_words = tokenize(v.dev.raw);
v.iast_words = tokenize(v.iast.raw);
v.eng_words = tokenize(v.eng.raw);

Hymn parseHymn(const std::string& text) {
    Hymn hymn;

    auto verseBlocks = splitVerses(text);

    for (size_t i = 0; i < verseBlocks.size(); ++i) {
        Verse v = parseVerse(verseBlocks[i], i + 1);

        v.dev_words = tokenize(v.dev.raw);
        v.iast_words = tokenize(v.iast.raw);
        v.eng_words = tokenize(v.eng.raw);

        hymn.verses.push_back(v);
    }

    return hymn;
}

int main() {
    std::string text = readFile("hymn.txt");

    Hymn hymn = parseHymn(text);

    for (const auto& v : hymn.verses) {
        std::cout << "Verse " << v.number << "\n";
        std::cout << "DEV: " << v.dev.raw << "\n";
        std::cout << "Words: " << v.dev_words.size() << "\n\n";
    }
}