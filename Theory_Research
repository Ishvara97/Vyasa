// Letters make Syllables now:

class Letter {
private:
 string value, base;

 LetterType type; //Vowel or Consonant
 consonantClass cclass; 

 Swara swara;
 bool hasSwara;

public: //Getters/Setters
	Letter() = default;
	Letter(const std::string& val) : value(val) {} //Construct Value
	Letter(const std::string& lbase) : base(lbase) {} //Construct Base

	Letter(const std::LetterType& ltype) : type(ltype) {}//Construct Type
	Letter(const std::consonantClass& lclass) : cclass(lclass) {}//Construct CClass

	Letter(const std::Swara& lswara) : swara(lswara) {} //Construct Swara

	Letter(bool std::hasSwara& lhasSwara) : hasSwara(lhasSwara) {} //Construct if HasSwara/Not


	//Read Write Values
	std::string getValue() const {return value;}
	void setValue(const std::string& val) { value = val; }
	//Read Write Bases
	std::string getBase() const {return base;}
	void setBase(const std::string& lbase) { base = lbase;}
	//R/W LetterType
	std::LetterType getLType() const {return type;}
	void setLType(const std::LetterType& ltype) { type = ltype;}
	//R/W Class
	std::consonantClass getcClass() const {return cclass;}
	void setcClass(const std::consonantClass& lclass) { cclass = lclass;}
	//R/W Swara
	std::Swara getSwara() const {return swara;}
	void setSwara(const std::Swara& lswara) { swara = lswara;}
	//R/W Bool
	std::bool isHasSwara() const {return hasSwara;}
	void setHasSwara(const std::bool& nullSwara) { hasSwara = nullSwara;}

}

